# Local Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://basalt:basalt@localhost:5432/basalt
DATABASE_URL_READONLY=postgresql://basalt_readonly:basalt_readonly@localhost:5432/basalt

# Better Auth (required for dev/build/runtime; use a long random value in production)
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default dev owner (after pnpm db:seed): tj@test.com / basalt — change in production

# External REST (`/api/v1/*`): max authenticated requests per API key per 60-second window (default 120)
# API_KEY_RATE_LIMIT_PER_MINUTE=120
# Same window: max requests per client IP before API key auth (default 600; curbs invalid-key floods)
# API_V1_RATE_LIMIT_PER_IP_PER_MINUTE=600
